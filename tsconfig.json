{
  "compilerOptions": {
    "module": "es2020",
    "target": "ES2021",
    "esModuleInterop": true,
    "strictNullChecks": true,
    "moduleResolution": "node",
    "allowJs": true,
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./lib",
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src/**/*.ts"]
}