{
  "name": "@cognitive3d/three-mattercraft",
  "version": "1.0.3",
  "description": "Seamlessly integrates the Cognitive3D WebXR SDK into Zappar's Mattercraft platform.",
  "keywords": [
    "xr",
    "vr",
    "sdk",
    "cognitive",
    "analytics",
    "mattercraft",
    "zappar",
    "threejs",
    "c3d",
    "cognitive3d",
    "webxr"
  ],
  "homepage": "https://github.com/CognitiveVR/mattercraft-cognitive3d#readme",
  "bugs": {
    "url": "https://github.com/CognitiveVR/mattercraft-cognitive3d/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CognitiveVR/mattercraft-cognitive3d.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Cognitive3D support@cognitive3d.com",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./lib/*": "./lib/*"
  },
  "zexports": [
    "./lib/**/*"
  ],
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib/**/*"
  ],
  "scripts": {
    "build": "rimraf lib && node -e \"require('fs').mkdirSync('src/vendor',{recursive:true});require('fs').copyFileSync('node_modules/@cognitive3d/analytics/lib/c3d-bundle-threejs.umd.js','src/vendor/c3d-bundle-threejs.umd.js')\" && tsc && node -e \"require('fs').mkdirSync('lib/vendor',{recursive:true});require('fs').copyFileSync('src/vendor/c3d-bundle-threejs.umd.js','lib/vendor/c3d-bundle-threejs.umd.js')\"",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@cognitive3d/analytics": "^2.6.4"
  },
  "peerDependencies": {
    "@zcomponent/core": "^1.0.0",
    "@zcomponent/html": "1.x",
    "@zcomponent/three": "^1.0.0",
    "@zcomponent/three-webxr": "^1.1.2",
    "three": "0.150.1 - 0.164.0"
  },
  "devDependencies": {
    "@types/three": "0.164.0",
    "@zcomponent/core": "^1.28.0",
    "@zcomponent/three": "^1.37.0",
    "@zcomponent/three-webxr": "^1.3.2",
    "rimraf": "^6.1.3",
    "three": "0.164.0",
    "typescript": "4.9.4"
  }
}